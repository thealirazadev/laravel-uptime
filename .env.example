# App name shown in mail subjects and page titles
APP_NAME=laravel-uptime
# Environment: local | production
APP_ENV=local
# Generate with: php artisan key:generate (also encrypts stored alert-channel configs)
APP_KEY=
# Never true outside local
APP_DEBUG=true
# Base URL used in alert links and status page URLs
APP_URL=http://localhost:8000
# All times stored and rendered in UTC
APP_TIMEZONE=UTC

# Log channel and minimum level
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local dev: sqlite (file defaults to database/database.sqlite)
DB_CONNECTION=sqlite
# Production: switch to mysql and set the block below
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=uptime
# DB_USERNAME=uptime
# DB_PASSWORD=dummy-password

# Queue jobs live in the database (jobs table); run: php artisan queue:work
QUEUE_CONNECTION=database
# Cache and atomic locks (cache_locks) on the database
CACHE_STORE=database
# Sessions in the database
SESSION_DRIVER=database

# SMTP used for mail alert channels
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=dummy-user
MAIL_PASSWORD=dummy-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=alerts@example.com
MAIL_FROM_NAME="laravel-uptime"

# Slack/webhook URLs are NOT env vars — they are per alert channel, encrypted in the database.

# SSL expiry warning thresholds in days, descending CSV
UPTIME_SSL_WARN_DAYS=30,14,7
# Days of raw check rows kept before pruning
UPTIME_RAW_RETENTION_DAYS=7
# Days of hourly rollups kept
UPTIME_HOURLY_RETENTION_DAYS=90
# Days of daily rollups kept
UPTIME_DAILY_RETENTION_DAYS=365
# User agent sent on HTTP checks and outbound webhooks
UPTIME_HTTP_USER_AGENT="laravel-uptime/1.0"
